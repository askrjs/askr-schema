{
  "name": "@askrjs/schema",
  "version": "0.0.2",
  "description": "Executable schemas with deterministic OpenAPI projection for Askr",
  "keywords": [
    "askr",
    "openapi",
    "schema",
    "validation"
  ],
  "homepage": "https://github.com/askrjs/askr-schema#readme",
  "bugs": {
    "url": "https://github.com/askrjs/askr-schema/issues"
  },
  "license": "Apache-2.0",
  "author": {
    "name": "askrjs",
    "url": "https://github.com/askrjs"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/askrjs/askr-schema.git"
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vp pack",
    "lint": "vp lint src && npm run typecheck",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vp test run",
    "test:types": "npm run build && tsc -p tests/types/tsconfig.json",
    "test:publint": "publint",
    "pack:check": "npm pack --ignore-scripts --dry-run --json",
    "check": "npm run lint && npm run typecheck && npm test && npm run test:types && npm run build && npm run test:publint && npm run pack:check",
    "prepack": "npm run build",
    "prepublishOnly": "npm run check"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "publint": "^0.3.12",
    "typescript": "^6.0.0",
    "vite-plus": "^0.2.4",
    "vitest": "^4.0.0"
  },
  "engines": {
    "node": ">=18"
  }
}
